# ══════════════════════════════════════════════════════════════════════════════
#  .gitignore
# ══════════════════════════════════════════════════════════════════════════════

# ── Environment files ─────────────────────────────────────────────────────────
# NEVER commit real environment files. Only .env.example is safe to commit.
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Build output ──────────────────────────────────────────────────────────────
dist/
build/

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Runtime data ──────────────────────────────────────────────────────────────
pids/
*.pid
*.seed
*.pid.lock

# ── Log files (keep directory, ignore contents) ───────────────────────────────
logs/*.log
logs/*.log.gz

# ── Uploaded files (keep directory, ignore contents) ─────────────────────────
uploads/*
!uploads/.gitkeep

# ── Coverage reports ──────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ── OS generated ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDE / Editor ──────────────────────────────────────────────────────────────
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
