# ══════════════════════════════════════════════════════════════════════════════
#  .env.example
#  Template for all required environment variables.
#
#  HOW TO USE
#  ─────────────
#  1. Copy this file to .env:
#       cp .env.example .env
#  2. Fill in every value with your REAL credentials.
#  3. NEVER commit .env to version control.
#  4. For production, inject variables via your secret manager
#     (AWS Secrets Manager, HashiCorp Vault, Doppler, etc.)
#
#  IMPORTANT
#  ─────────────
#  • This file is committed to the repository intentionally — it documents
#    the shape of the required configuration WITHOUT exposing any secrets.
#  • Every variable listed here is validated at startup. The app will NOT
#    start if any required variable is missing or malformed.
# ══════════════════════════════════════════════════════════════════════════════


# ── Application ───────────────────────────────────────────────────────────────

# Runtime environment. Must be: development | production | test
NODE_ENV=development

# HTTP port the Express server listens on.
PORT=5000

# Allowed CORS origin. In production set this to your exact frontend URL.
# Example: https://app.yourdomain.com
CORS_ORIGIN=http://localhost:3000


# ── MongoDB ───────────────────────────────────────────────────────────────────

# Full MongoDB connection string.
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<database>
# REQUIRED. Never use a shared or default URI in production.
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority


# ── JSON Web Tokens ───────────────────────────────────────────────────────────

# Secret used to sign ACCESS tokens.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Must be at least 32 characters. REQUIRED.
JWT_ACCESS_SECRET=<replace-with-random-hex-string-min-32-chars>

# Secret used to sign REFRESH tokens.
# Must be DIFFERENT from JWT_ACCESS_SECRET. At least 32 characters. REQUIRED.
JWT_REFRESH_SECRET=<replace-with-different-random-hex-string-min-32-chars>

# Access token expiry. Use number (seconds) or shorthand: 15m, 1h, 2d
JWT_ACCESS_EXPIRY=15m

# Refresh token expiry. Use number (seconds) or shorthand: 7d, 30d
JWT_REFRESH_EXPIRY=7d


# ── Email / SMTP ──────────────────────────────────────────────────────────────

# SMTP server hostname.
# Examples: smtp.sendgrid.net | smtp.mailgun.org | smtp.gmail.com
EMAIL_HOST=smtp.sendgrid.net

# SMTP port. Common values: 587 (STARTTLS) | 465 (SSL) | 25
EMAIL_PORT=587

# SMTP authentication username (often your email address or "apikey" for SendGrid).
EMAIL_USER=apikey

# SMTP authentication password or API key. REQUIRED. Never commit real values.
EMAIL_PASS=<your-smtp-password-or-api-key>

# The "From" header used when sending emails.
# Example: MyApp <no-reply@myapp.com>
EMAIL_FROM=MyApp <no-reply@myapp.com>


# ── Payment Gateway (Stripe) ──────────────────────────────────────────────────

# Stripe secret API key.
# • Development / testing: sk_test_...
# • Production:            sk_live_...
# REQUIRED. Never commit live keys.
STRIPE_SECRET_KEY=sk_test_<your-stripe-secret-key>

# Stripe webhook signing secret — found in your Stripe dashboard under
# Developers → Webhooks → your endpoint → Signing secret.
# Format: whsec_...
STRIPE_WEBHOOK_SECRET=whsec_<your-stripe-webhook-signing-secret>


# ── Cloud Storage (AWS S3 / S3-compatible) ────────────────────────────────────

# AWS Access Key ID (or equivalent for other providers like MinIO / DigitalOcean Spaces).
CLOUD_STORAGE_ACCESS_KEY=<your-cloud-storage-access-key-id>

# AWS Secret Access Key. REQUIRED. Never commit this value.
CLOUD_STORAGE_SECRET_KEY=<your-cloud-storage-secret-access-key>

# S3 bucket name.
CLOUD_STORAGE_BUCKET=your-bucket-name

# AWS region (e.g. us-east-1, eu-west-1).
CLOUD_STORAGE_REGION=us-east-1

# (Optional) Custom endpoint for S3-compatible services.
# Leave commented out for standard AWS S3.
# CLOUD_STORAGE_ENDPOINT=https://nyc3.digitaloceanspaces.com


# ── Security & Logging ────────────────────────────────────────────────────────

# bcrypt cost factor. Minimum 12 (OWASP ASVS §2.4.1). Higher = slower + safer.
BCRYPT_COST_FACTOR=12

# Log level. Options: error | warn | info | http | debug
LOG_LEVEL=info

# Comma-separated list of trusted IP addresses that bypass rate limiting.
# Leave empty in production unless you have a known monitoring IP.
TRUSTED_IPS=

# cookie-parser secret for signed cookies (min 32 chars).
COOKIE_SECRET=<replace-with-random-hex-string-min-32-chars>

# ── Sprint 2: CSRF + File Download ───────────────────────────────────────────

# CSRF double-submit cookie secret (min 32 chars, different from COOKIE_SECRET).
CSRF_SECRET=<replace-with-random-hex-string-min-32-chars-different>

# HMAC secret for signed file download URLs (min 32 chars).
DOWNLOAD_SECRET=<replace-with-random-hex-string-min-32-chars-different>
