# Copy this file to .env and fill in real values. Never commit .env itself.

PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string (from your Atlas cluster)
MONGO_URI=mongodb://localhost:27017/program

# Long random string used to sign JWTs. Generate one with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string

# How long the JWT (and cookie) stays valid
JWT_EXPIRES_IN=7d

# The exact URL of your deployed frontend (no trailing slash).
# In development this is your Vite dev server.
CLIENT_URL=http://localhost:5173

# From your Cloudinary dashboard (cloudinary.com/console) — free tier is fine for MVP
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
